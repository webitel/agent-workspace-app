{
	"name": "@webitel/agent-workspace-app",
	"version": "0.0.0",
	"private": false,
	"type": "module",
	"engines": {
		"node": ">=24",
		"npm": ">=11"
	},
	"scripts": {
		"dev": "vite --force",
		"build": "vite build",
		"preview": "vite preview",
		"test:unit": "vitest run",
		"lint:fix": "npx biome check --write ./src",
		"lint:fix-staged": "npx lint-staged",
		"test:e2e": "playwright test",
		"typecheck": "vue-tsc --build",
		"prepare": "husky || true",
		"biome:ci:gh": "biome ci ./src --reporter=github",
		"test:unit:ci": "vitest run --coverage",
		"typecheck:ci": "npm run typecheck"
	},
	"dependencies": {
		"@webitel/api-services": "^0.1.40",
		"@webitel/chat-web-sdk": "^0.0.19",
		"@webitel/ui-chats": "^0.1.39",
		"@webitel/ui-sdk": "^26.6.47",
		"axios": "^1.17.0",
		"pinia": "^3.x",
		"vue": "^3.5.x",
		"vue-i18n": "^11.4.6",
		"vue-router": "^5.1.x",
		"webitel-sdk": "^26.4.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@pinia/testing": "^1.0.3",
		"@playwright/test": "^1.61.0",
		"@types/node": "^25.9.2",
		"@vitejs/plugin-vue": "^6.x",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.9.1",
		"husky": "^9.1.7",
		"jsdom": "^27.0.0",
		"lint-staged": "^17.x",
		"npm-run-all2": "^8.0.4",
		"typescript": "~5.9.x",
		"typescript-plugin-css-modules": "^5.x",
		"vite": "^8.x",
		"vite-plugin-vue-devtools": "^8.1.x",
		"vitest": "^4.x",
		"vue-tsc": "^3.3.5"
	},
	"overrides": {
		"vue-router": "^5.1.x",
		"axios": "^1.17.0"
	}
}
